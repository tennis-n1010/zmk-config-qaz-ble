#include "layouts/WK_DOUBLE_SPACE.dtsi"
#include "layouts/WK_SINGLE_SPACE.dtsi"
#include "layouts/WK_LONG_SPACE.dtsi"
#include "layouts/WK_TRIPLE_SPACE.dtsi"
#include "layouts/HHKB_DOUBLE_SPACE.dtsi"
#include "layouts/HHKB_SINGLE_SPACE.dtsi"
#include "layouts/HHKB_LONG_SPACE.dtsi"
#include "layouts/HHKB_TRIPLE_SPACE.dtsi"
#include "layouts/WKL_DOUBLE_SPACE.dtsi"
#include "layouts/WKL_SINGLE_SPACE.dtsi"
#include "layouts/WKL_LONG_SPACE.dtsi"
#include "layouts/WKL_TRIPLE_SPACE.dtsi"
#include "layouts/position_map.dtsi"

&qaz_ble_wk_double_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};

&qaz_ble_wk_single_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_wk_long_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_wk_triple_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_hhkb_double_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};

&qaz_ble_hhkb_single_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_hhkb_long_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_hhkb_triple_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_wkl_double_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};

&qaz_ble_wkl_single_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_wkl_long_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};
&qaz_ble_wkl_triple_space_layout {
    transform = <&qaz_ble_wk_defaoult_transform>;
};

    qaz_ble_wk_defaoult_transform: qaz_ble_wk_defaoult_transform {
        compatible = "zmk,matrix-transform";
        rows       = <5>;
        columns    = <11>;
        map = <
            /* row-0 */ RC(1,0)RC(1,2) RC(1,3) RC(1,4) RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9) RC(1,10)
            /* row-1 */ RC(2,0) RC(2,1) RC(2,3) RC(2,4) RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9) RC(2,10)
            /* row-2 */ RC(3,0) RC(3,2) RC(3,4) RC(3,5) RC(3,6) RC(3,7) RC(3,8) RC(3,9) RC(3,10)
            /* row-3 */ RC(4,0) RC(4,1) RC(4,2) RC(4,5) RC(4,7) RC(4,8) RC(4,9) RC(4,10)
            /* tactile switches */ RC(0,8) RC(0,9) RC(0,10)
        >;
    };