#include <dt-bindings/zmk/matrix_transform.h>
#include "physical_layouts.dtsi"

/ {
    compatible = "qaz_num_ble,shield";

    chosen {
        zmk,kscan = &kscan0;
        zmk,physical-layout = &qaz_num_ble_macropad_layout;
        zmk,studio-rpc = &studio_usb;
    };
    
    qaz_num_ble_default_transform: qaz_num_ble_default_transform {
    compatible = "zmk,matrix-transform";
     rows       = <5>;
    columns    = <5>;
        map = <
            /* row-0 */ RC(0,1) RC(0,2) RC(0,3) RC(0,4)
            /* row-1 */ RC(1,0) RC(1,2) RC(1,3) RC(1,4)
            /* row-2 */ RC(2,0) RC(2,1) RC(2,3) RC(2,4)
            /* row-3 */ RC(3,0) RC(3,1) RC(3,2) RC(3,4)
            /* row-4 */ RC(4,0) RC(4,1) RC(4,2) RC(4,3)
        >;
};
};
